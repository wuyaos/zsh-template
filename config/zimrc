# Start configuration added by Zim install {{{
#
# This is not sourced during shell startup, and it's only used to configure the
# zimfw plugin manager.
#

#
# Official core modules
#

# Baseline shell options and environment defaults.
zmodule environment
# Git aliases and helper functions.
zmodule git
# Keybindings and input behavior integration.
zmodule input
# Terminal title updates based on context.
zmodule termtitle
# Common utility aliases and safer defaults.
zmodule utility

#
# Prompt modules
#

# Prompt theme engine.
zmodule romkatv/powerlevel10k
# Exposes last command duration for prompt segments.
zmodule duration-info
# Exposes git status metadata for prompt segments.
zmodule git-info
# Exposes current directory info for prompt segments.
zmodule prompt-pwd

#
# Completion modules
#

# Extra completion definitions from community.
zmodule zsh-users/zsh-completions --fpath src
# Core Zsh completion system.
zmodule completion

#
# Project local modules
#

# Local conda/micromamba compatibility aliases and prompt helpers.
zmodule ${${(%):-%x}:A:h:h}/modules/conda \
  --if '(( ${+commands[conda]} || ${+commands[micromamba]} || ${+commands[mamba]} ))'
# Local numpad key sequence mappings for terminal application mode.
zmodule ${${(%):-%x}:A:h:h}/modules/numpad

#
# Optional extra modules
#

# Fuzzy directory jump via fzf + fasd integration.
zmodule wookayin/fzf-fasd --if '(( ${+commands[fzf]} && ${+commands[fasd]} ))'
# zmodule Aloxaf/fzf-tab

#
# Modules that must be initialized last
#

# Syntax highlighting for typed commands.
zmodule zsh-users/zsh-syntax-highlighting
# Up/down history search based on current command substring.
zmodule zsh-users/zsh-history-substring-search
# Fish-like inline command suggestions; keep last for stable widget bindings.
zmodule zsh-users/zsh-autosuggestions
# }}} End configuration added by Zim install
